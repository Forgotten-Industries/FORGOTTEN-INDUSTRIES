---
layout: base.njk
title: Posts
description: Manuscripts, manifestos, and curated entries from the Forgotten Industries archive.
permalink: /posts/index.html
eleventyExcludeFromCollections: true
---
<section class="masthead">
  <div class="section-inner">
    <p class="section-label">Manuscripts</p>
    <h1>Posts</h1>
    <p class="tagline">{{ description }}</p>
  </div>
</section>

<section class="evidence-band">
  <div class="section-inner">
    <ul class="lane-list" aria-label="All posts">
      {% for post in collections.posts | reverse %}
      <li>
        <span>
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
          {% if post.data.type %}/ {{ post.data.type }}{% endif %}
        </span>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {% if post.data.description %}
        <p>{{ post.data.description }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>
